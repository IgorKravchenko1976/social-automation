# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel

# Facebook
FACEBOOK_PAGE_ID=your-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token

# X / Twitter
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
TWITTER_BEARER_TOKEN=your-bearer-token

# Instagram
INSTAGRAM_USERNAME=your-username
INSTAGRAM_PASSWORD=your-password

# TikTok
TIKTOK_CLIENT_KEY=your-client-key
TIKTOK_CLIENT_SECRET=your-client-secret
TIKTOK_ACCESS_TOKEN=your-access-token

# Pexels (free stock images)
PEXELS_API_KEY=your-pexels-api-key

# App info (used for AI content generation context)
APP_NAME=YourAppName
APP_DESCRIPTION=Short description of your app for AI context
APP_WEBSITE=https://yourapp.com

# Scheduling (24h format, comma-separated)
POST_TIMES=09:00,13:00,18:00
TIMEZONE=Europe/Kyiv

# Webhook
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_SECRET=random-secret-string

# Admin API key (protects all write/admin/trigger endpoints)
ADMIN_API_KEY=generate-a-strong-random-key-here

# --- Блог на сайт (один з варіантів) ---

# Рекомендовано: push через API #2 (без SFTP на VPS). Той самий MARKETING_PUBLISH_API_KEY, що в .env сервера.
MARKETING_PUBLISH_API_BASE=https://api-v2.im-in.net/v1/api/internal/marketing
MARKETING_PUBLISH_API_KEY=
# Звідки тягнути blog.html, index.html… (порожньо = raw з GitLab imin-backend web/marketing)
MARKETING_TEMPLATE_BASE_URL=

# Застаріло: SFTP на VPS (якщо API-ключ вище не заданий — використовується це)
VPS_SSH_HOST=
VPS_SSH_PORT=22
VPS_SSH_USER=deploy
VPS_SSH_PASSWORD=
VPS_SSH_KEY=
VPS_BLOG_PATH=/var/www/im-in.net/html/blog

# --- Geo-Research Bot (бот-дослідник) ---
# Бот бере завдання з imin-backend API і відправляє результати AI-дослідження
IMIN_BACKEND_API_BASE=https://api-v2.im-in.net
IMIN_BACKEND_SYNC_KEY=
